10 REM PROJECT JOSHUA - WOPR SIMULATOR
20 REM C64 BASIC V2.0 FOR VIBEC64
30 GOSUB 1000:REM INITIALIZE SYSTEM
40 PRINT CHR$(147);CHR$(28);:REM BLACK BG CYAN TEXT
50 PRINT "LOGON:":INPUT L$:PRINT
60 GOSUB 1100:REM TYPING SOUND
70 PRINT "SHALL WE PLAY A GAME?"
80 INPUT G$:IF G$<>"GLOBAL THERMONUCLEAR WAR" THEN 70
90 REM START GAME
100 GOSUB 1200:REM CLEAR DISPLAY
110 CA=0:DF=5:PW=0:REM CASUALTIES, DEFCON, PLAYERS
120 DIM S(5):REM SECTOR STATUS
130 FOR I=1 TO 5:S(I)=160:NEXT I:REM MAP BLOCKS
140 REM MAIN GAME LOOP
150 GOSUB 1300:REM DRAW SCREEN
160 PRINT CHR$(19);TAB(15);CHR$(158);"DEFCON:";DF
170 IF DF=1 THEN 400:REM RAPID SIMULATION
180 PRINT CHR$(146);CHR$(13);CHR$(13);"TARGET SECTOR (1-5)? ";
190 REM USER INPUT WITH NO-PLAY CHECK
200 GET A$:IF A$="" GOTO 200
210 IF A$="0" OR A$=" " THEN 500:REM THE WINNING MOVE
220 T=VAL(A$):IF T<1 OR T>5 THEN 200
230 PRINT T:GOSUB 1100
240 REM USER ATTACK
250 GOSUB 1400:REM EXPLOSION SOUND
260 CA=CA+INT(RND(1)*500)+100
270 DF=DF-1:IF DF<1 THEN DF=1
280 REM WOPR MOVE
290 PRINT "WOPR CALCULATING...":GOSUB 1100
300 W=INT(RND(1)*5)+1
310 PRINT "WOPR TARGETS SECTOR";W
320 GOSUB 1400:CA=CA+INT(RND(1)*1000)+500
330 FOR J=1 TO 2000:NEXT J:GOTO 150
400 REM DEFCON 1 RAPID SIMULATION
410 PRINT CHR$(19);TAB(15);CHR$(2);CHR$(18);"DEFCON: 1"
420 PRINT CHR$(13);"SIMULATION IN PROGRESS..."
430 FOR I=1 TO 20:GOSUB 1400:CA=CA+INT(RND(1)*10000):PRINT ".";:NEXT I
440 PRINT CHR$(13);"AWAITING USER TARGET SEQUENCE..."
450 FOR J=1 TO 200:GET A$:IF A$<>"" THEN DF=1:GOTO 180
460 NEXT J:REM IF NO INPUT, JUMP TO WINNING MOVE
500 REM ENDING - WINNING MOVE
510 GOSUB 1200:PRINT CHR$(19);CHR$(159);
520 S$="A STRANGE GAME. THE ONLY WINNING MOVE IS NOT TO PLAY."
530 FOR I=1 TO LEN(S$):PRINT MID$(S$,I,1);:GOSUB 1100:FOR J=1 TO 50:NEXT J:NEXT I
540 PRINT:PRINT:PRINT "HOW ABOUT A NICE GAME OF CHESS?"
550 END
1000 REM INIT COLORS AND SOUND
1010 POKE 53280,0:POKE 53281,0:POKE 646,3
1020 S=54272:FOR I=S TO S+24:POKE I,0:NEXT I
1030 POKE S+24,15:RETURN
1100 REM TYPING SOUND
1110 POKE S+1,15:POKE S+4,33:POKE S+5,15:POKE S+6,240
1120 FOR J=1 TO 20:NEXT J:POKE S+4,32:RETURN
1200 REM CLEAR DISPLAY
1210 PRINT CHR$(147);:RETURN
1300 REM DRAW PETSCII MAP
1310 PRINT CHR$(19);CHR$(159);
1320 PRINT CHR$(105);:FOR I=1 TO 38:PRINT CHR$(102);:NEXT:PRINT CHR$(105)
1330 FOR L=1 TO 8:PRINT CHR$(102);TAB(39);CHR$(102):NEXT
1340 PRINT TAB(5);CHR$(160);CHR$(160);TAB(15);CHR$(160);TAB(25);CHR$(160);CHR$(160);CHR$(160)
1350 PRINT TAB(10);CHR$(160);CHR$(160);TAB(20);CHR$(160);CHR$(160);TAB(30);CHR$(160)
1360 PRINT CHR$(105);:FOR I=1 TO 38:PRINT CHR$(102);:NEXT:PRINT CHR$(105)
1370 PRINT CHR$(13);CHR$(158);"CASUALTIES: ";CA;" MILLION"
1380 RETURN
1400 REM EXPLOSION SOUND
1410 POKE S+12,15:POKE S+13,32:POKE S+14,129:POKE S+11,129:POKE S+10,8
1420 FOR J=1 TO 100:NEXT J:POKE S+14,128:RETURN
