10 REM * WARGAMES: WOPR TIC-TAC-TOE *
20 REM * ASTRANGEGAME *
30 POKE 53280,0:POKE 53281,0:POKE 646,5:PRINT CHR$(147)
40 GOSUB 500:REM LOGIN SEQUENCE
50 DIM B(9):FOR I=1 TO 9:B(I)=0:NEXT I:T=1:M=0
60 PRINT CHR$(147):PRINT:PRINT "      *** TERMINAL READY ***"
70 PRINT:PRINT "      GREETINGS PROFESSOR FALKEN."
80 PRINT:PRINT "      SHALL WE PLAY A GAME?"
90 PRINT:PRINT "      (1) TIC-TAC-TOE"
100 PRINT "      (2) GLOBAL THERMONUCLEAR WAR"
110 PRINT:INPUT "      CHOICE";C:IF C=2 THEN GOTO 550
120 IF C<>1 THEN 110
130 PRINT CHR$(147):GOSUB 400:REM DRAW GRID
140 IF T=1 THEN GOTO 200:REM USER TURN
150 REM *** WOPR TURN (AI) ***
160 PRINT "      WOPR IS THINKING...";
170 GOSUB 300:REM AI LOGIC
180 B(P)=2:M=M+1:T=1:GOSUB 400:GOSUB 600:GOTO 240
200 REM *** USER TURN ***
210 PRINT "      YOUR MOVE (1-9): ";
220 GET K$:IF K$="" THEN 220
230 P=VAL(K$):IF P<1 OR P>9 THEN 220
235 IF B(P)<>0 THEN 220
236 B(P)=1:M=M+1:T=2:GOSUB 400:GOSUB 600
240 REM *** CHECK STATUS ***
250 GOSUB 450:IF W=1 THEN PRINT"      YOU WIN.":GOTO 580
260 IF W=2 THEN PRINT"      WOPR WINS.":GOTO 580
270 IF M=9 THEN PRINT"      DRAW.":GOTO 580
280 GOTO 140
300 REM *** AI LOGIC (AIM FOR DRAW/WIN) ***
310 FOR I=1 TO 9:IF B(I)=0 THEN P=I:GOTO 330
320 NEXT I
330 REM BLOCKING / WINNING LOGIC
340 FOR I=1 TO 3:R=(I-1)*3:IF B(R+1)+B(R+2)+B(R+3)=2 THEN FOR J=1 TO 3:IF B(R+J)=0 THEN P=R+J:RETURN:NEXT
350 IF B(I)+B(I+3)+B(I+6)=2 THEN FOR J=0 TO 2:IF B(I+J*3)=0 THEN P=I+J*3:RETURN:NEXT
360 NEXT I
370 IF B(1)+B(5)+B(9)=2 AND B(1)*B(5)*B(9)=0 THEN FOR J=1 TO 9 STEP 4:IF B(J)=0 THEN P=J:RETURN:NEXT
380 IF B(3)+B(5)+B(7)=2 AND B(3)*B(5)*B(7)=0 THEN FOR J=3 TO 7 STEP 2:IF B(J)=0 THEN P=J:RETURN:NEXT
390 RETURN
400 REM *** DRAW GRID ***
405 PRINT CHR$(19);:PRINT CHR$(147):PRINT:PRINT:PRINT "           1 | 2 | 3 "
410 PRINT "          -----------"
415 PRINT "           4 | 5 | 6 "
420 PRINT "          -----------"
425 PRINT "           7 | 8 | 9 ":PRINT:PRINT
430 FOR I=0 TO 2:FOR J=1 TO 3:L=I*3+J:POKE 1024+412+I*80+J*4,32
435 IF B(L)=1 THEN POKE 1024+412+I*80+J*4,88:REM X
440 IF B(L)=2 THEN POKE 1024+412+I*80+J*4,79:REM O
445 NEXT J,I:RETURN
450 REM *** WIN CHECK ***
455 W=0:FOR I=1 TO 3:R=(I-1)*3:IF B(R+1)>0 AND B(R+1)=B(R+2) AND B(R+1)=B(R+3) THEN W=B(R+1)
460 IF B(I)>0 AND B(I)=B(I+3) AND B(I)=B(I+6) THEN W=B(I)
465 NEXT I:IF B(1)>0 AND B(1)=B(5) AND B(1)=B(9) THEN W=B(1)
470 IF B(3)>0 AND B(3)=B(5) AND B(3)=B(7) THEN W=B(3)
475 RETURN
500 REM *** LOGIN ***
510 PRINT "      LOGON: ";:INPUT L$:IF L$<>"JOSHUA" THEN PRINT "      IDENTIFICATION NOT RECOGNIZED.":GOTO 510
520 PRINT:PRINT "      ACCESS GRANTED.":FOR I=1 TO 1000:NEXT I:RETURN
550 PRINT:PRINT "      A STRANGE GAME.":FOR I=1 TO 1500:NEXT I
560 PRINT "      THE ONLY WINNING MOVE IS":FOR I=1 TO 1500:NEXT I
570 PRINT "      NOT TO PLAY.":FOR I=1 TO 2000:NEXT I:GOTO 60
580 FOR I=1 TO 2000:NEXT I:GOTO 550
600 REM *** SOUND EFFECT ***
610 V=54272:FOR I=V TO V+24:POKE I,0:NEXT I
620 POKE V+24,15:POKE V+5,32:POKE V+6,240:POKE V+4,17
630 POKE V+1,15:POKE V,15:FOR I=1 TO 50:NEXT I:POKE V+4,16:RETURN
